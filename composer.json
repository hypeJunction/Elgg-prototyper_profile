{
	"name": "hypejunction/prototyper_profile",
	"type": "elgg-plugin",
	"description": "hypePrototyper integration for Elgg user profiles",
	"homepage": "https://github.com/hypeJunction/Elgg-prototyper_profile",
	"keywords": [
		"elgg",
		"plugin",
		"profile",
		"profile builder",
		"form builder",
		"prototyper"
	],
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"extra": {
		"elgg-plugin": {
			"id": "prototyper_profile"
		}
	},
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.1",
		"elgg/elgg": "~6.1.0",
		"ext-intl": "*"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\PrototyperProfile\\": "classes/hypeJunction/PrototyperProfile/"
		}
	}
}
